{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "plan",
  // Disables the "/share" command to make a session publicly available.
  "share": "disabled",
  // Controls which actions require approval to run.
  "permission": {
    "external_directory": {
      "~/.config/opencode/skills/**": "allow",
      "~/.cargo/registry/**": "allow",
      "~/.agents/skills/**": "allow"
    }
  },
  // keeps built-ins enabled while configuring overrides or custom servers.
  "lsp": {
    "marksman": {
      "command": ["marksman", "server"],
      "extensions": [".md"]
    },
    "biome": {
      "command": ["biome", "lsp-proxy"],
      "extensions": [".ts", ".js"]
    },
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py"]
    },
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py"]
    },
    "tsgo": {
      "command": ["tsgo", "--lsp", "--stdio"],
      "extensions": [".ts", ".js", ".tsx", ".jsx"]
    }
  },
  // Keeps built-ins enabled while configuring overrides or custom formatters.
  "formatter": {
    "rumdl": {
      "command": ["rumdl", "fmt", "$FILE"],
      "extensions": [".md"]
    },
    "opentofu": {
      "command": ["tofu", "fmt", "$FILE"],
      "extensions": [".tf", ".tfvars"]
    }
  }
}
